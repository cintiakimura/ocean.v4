# --- REQUIRED INFRASTRUCTURE ---
# Get these from Supabase Dashboard -> Settings -> API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
JWT_SECRET="your-jwt-secret"

# --- GITHUB OAUTH ---
# Get these from GitHub -> Settings -> Developer settings -> OAuth Apps
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# --- SECURITY ---
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is used to encrypt user-supplied keys in the database.
ENCRYPTION_KEY="your-32-byte-hex-key"

# --- APP CONFIG ---
# The base URL of your application (e.g., https://your-app.run.app)
APP_URL="https://your-app.run.app"

# --- AI SERVICES ---
# Get this from console.x.ai
GROK_KEY="your-grok-api-key"

# --- DEPLOYMENT (OPTIONAL) ---
# Get this from Vercel -> Settings -> Git -> Deploy Hooks
VERCEL_DEPLOY_HOOK="https://api.vercel.com/v1/integrations/deploy/..."
